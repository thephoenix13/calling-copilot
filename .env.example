# ─────────────────────────────────────────────────────────────────────
# Recruiter Call App — environment variables (reference / template)
#
# LOCAL:  copy this to `.env` and fill in values. Your `.env` is gitignored
#         and never leaves your machine.
# RENDER: set these in the dashboard (Environment tab). Render does NOT read
#         this file or your local `.env`.
#
# Because local uses `.env` and Render uses its dashboard, the two
# environments never collide — editing one cannot break the other.
# ─────────────────────────────────────────────────────────────────────

# ── Required for the web UI ──────────────────────────────────────────
# Secret used to sign login JWTs. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string

# Claude API key — powers JD enhancement, Ask-MIS, AI reports, suggestions.
ANTHROPIC_API_KEY=sk-ant-...

# Public URL of the frontend, used to build links inside emails.
# Local:  http://localhost:5173
# Render: https://<your-frontend>.onrender.com
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Backend port. LOCAL ONLY — Render injects PORT automatically,
# so do NOT set this on Render.
PORT=3000

# ── Frontend (client) build-time variable ────────────────────────────
# The React app reads VITE_BACKEND_URL at build time; if unset it falls
# back to http://localhost:3000. Set it in client/.env locally, or in the
# Render Static Site's environment.
# VITE_BACKEND_URL=http://localhost:3000

# ── Optional: email (invites, password reset, POFU follow-ups) ───────
# Leave blank to disable outbound email.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Recruiter App
SMTP_FROM_EMAIL=
SMTP_REPLY_TO=

# ── Deferred: live calling + transcription (leave unset for now) ─────
# Needed only when you wire up Twilio voice + Deepgram transcription.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_API_KEY=
# TWILIO_API_SECRET=
# TWILIO_TWIML_APP_SID=
# TWILIO_PHONE_NUMBER=
# DEEPGRAM_API_KEY=
# NGROK_URL=
